{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capabilities for the main DJ Uploader window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:window:allow-set-focus",
    "core:window:allow-start-dragging",
    "core:event:default",
    "dialog:default",
    "dialog:allow-open",
    "opener:default",
    "opener:allow-open-url",
    "process:allow-restart",
    "updater:default"
  ]
}
