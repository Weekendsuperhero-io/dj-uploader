{
  "name": "dj-uploader",
  "private": true,
  "version": "2026.7.2",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "typecheck": "tsc --noEmit",
    "test": "cargo test --manifest-path src-tauri/Cargo.toml",
    "preview": "vite preview",
    "tauri": "tauri",
    "op:dev": "op run --env-file=.env.1password -- tauri dev",
    "op:build": "./scripts/with-appstore-key.sh op run --env-file=.env.1password -- tauri build",
    "op:build:universal": "./scripts/with-appstore-key.sh op run --env-file=.env.1password -- tauri build --target universal-apple-darwin",
    "op:release": "./scripts/with-appstore-key.sh op run --env-file=.env.1password -- ./scripts/create-release.sh"
  },
  "dependencies": {
    "@phosphor-icons/react": "^2.1.10",
    "@tauri-apps/api": "^2.11.1",
    "@tauri-apps/plugin-dialog": "^2.7.1",
    "@tauri-apps/plugin-opener": "^2.5.4",
    "@tauri-apps/plugin-process": "^2.3.1",
    "@tauri-apps/plugin-updater": "^2.10.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.4.0",
    "lucide-react": "^0.469.0",
    "radix-ui": "^1.6.2",
    "react": "^19.2.7",
    "react-day-picker": "^10.0.1",
    "react-dom": "^19.2.7",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.2",
    "@tauri-apps/cli": "^2.11.4",
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "tailwindcss": "^4.3.2",
    "typescript": "^7.0.2",
    "vite": "^8.1.4"
  },
  "packageManager": "pnpm@11.11.0"
}
